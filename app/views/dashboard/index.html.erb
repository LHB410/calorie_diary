<div class="dashboard" data-controller="date-navigation" data-date-navigation-current-date-value="<%= @current_date.iso8601 %>">
  <div class="dashboard-header">
    <h1>Daily Overview</h1>
    <div class="date-selector">
      <button data-action="click->date-navigation#previousDay" class="btn btn-secondary">← Previous</button>
      <span class="current-date" data-date-navigation-target="dateDisplay">
        <%= @current_date.strftime('%B %d, %Y') %>
      </span>
      <button data-action="click->date-navigation#nextDay" class="btn btn-secondary">Next →</button>
      <button data-action="click->date-navigation#goToToday" class="btn btn-outline">Today</button>
    </div>
  </div>

  <div class="calorie-summary">
    <div class="calorie-card">
      <h3>Total Calories</h3>
      <span class="calorie-count"><%= @daily_total.round %></span>
    </div>
  </div>

  <div class="meals-section">
    <div class="section-header">
      <h2>Today's Meals</h2>
      <%= link_to "Add Meal", new_meal_path(date: @current_date), class: "btn btn-primary" %>
    </div>

    <% if @meals.any? %>
      <div class="meals-grid">
        <% @meals.each do |meal| %>
          <div class="meal-card">
            <h4><%= link_to meal.name, meal_path(meal) %></h4>
            <p class="meal-calories"><%= meal.total_calories.round %> calories</p>
            <div class="meal-ingredients">
              <% meal.meal_ingredients.includes(:food).each do |ingredient| %>
                <span class="ingredient-tag">
                  <%= ingredient.food.name %> (<%= ingredient.weight_g %>g)
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">No meals recorded for this day.</p>
    <% end %>
  </div>
</div>
