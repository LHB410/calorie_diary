<!DOCTYPE html>
<html>
  <head>
    <title>Calorie Diary</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "application" %>
  </head>

  <body>
    <nav class="navbar">
      <div class="nav-container">
        <%= link_to "Calorie Diary", root_path, class: "nav-brand" %>
        <div class="nav-links">
          <%= link_to "Dashboard", root_path, class: "nav-link" %>
          <%= link_to "Meals", meals_path, class: "nav-link" %>
          <%= link_to "Foods", foods_path, class: "nav-link" %>
        </div>
      </div>
    </nav>

    <main class="main-content">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-error"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
